---
import fs from 'fs';
import path from 'path';
import { discordLaughMessages } from '../data/discordLaughMessages';

const rootImageFolder = path.join(process.cwd(), 'imagenes');
const publicImageFolder = path.join(process.cwd(), 'public', 'imagenes');
const sourceImageFolder = fs.existsSync(publicImageFolder) ? publicImageFolder : rootImageFolder;

const localProfileImages = fs.existsSync(sourceImageFolder)
  ? fs
      .readdirSync(sourceImageFolder)
      .filter((file) => /\.(png|jpe?g|webp|gif)$/i.test(file))
      .sort()
      .map((file) => `/imagenes/${encodeURIComponent(file)}`)
  : [];

const initialMessages = discordLaughMessages.map((message, index) => ({
  username: message.username,
  content: message.content,
  avatar: localProfileImages[index % localProfileImages.length] || message.avatar,
  color: message.color,
  timestamp: message.timestamp,
  isBot: message.isBot,
}));
---

<div class="discord-generator">
  <div class="discord-generator__controls">
    <h2 class="discord-generator__title">Discord Fake Message</h2>
    <p class="discord-generator__subtitle">Arma una conversación y ajusta cada mensaje.</p>

    <div class="discord-generator__field">
      <label for="discord-username">Usuario</label>
      <input id="discord-username" type="text" class="discord-generator__input" placeholder="NightWolf" />
    </div>

    <div class="discord-generator__field">
      <label for="discord-content">Mensaje</label>
      <textarea
        id="discord-content"
        class="discord-generator__input discord-generator__textarea"
        rows="4"
        placeholder="Escribe tu mensaje"
      ></textarea>
    </div>

    <div class="discord-generator__grid">
      <div class="discord-generator__field">
        <label for="discord-color">Color de nombre</label>
        <input id="discord-color" type="color" class="discord-generator__color" value="#59bfff" />
      </div>
      <div class="discord-generator__field">
        <label for="discord-time">Hora (HH:mm)</label>
        <input id="discord-time" type="text" class="discord-generator__input" value="1:46" />
      </div>
    </div>

    <div class="discord-generator__field">
      <label for="discord-avatar">Avatar URL</label>
      <input
        id="discord-avatar"
        type="text"
        class="discord-generator__input"
        placeholder="https://..."
      />
    </div>
    <div class="discord-generator__field">
      <label for="discord-avatar-file">Imagen de avatar</label>
      <input id="discord-avatar-file" type="file" class="discord-generator__input discord-generator__file" accept="image/*" />
    </div>

    <label class="discord-generator__checkbox">
      <input id="discord-bot" type="checkbox" />
      Marcar como BOT
    </label>

    <div class="discord-generator__actions">
      <button id="discord-add" class="discord-generator__button discord-generator__button--primary" type="button">
        Agregar
      </button>
      <button id="discord-update" class="discord-generator__button" type="button">
        Actualizar
      </button>
      <button id="discord-delete" class="discord-generator__button discord-generator__button--danger" type="button">
        Borrar
      </button>
      <button id="discord-reset" class="discord-generator__button" type="button">
        Limpiar todo
      </button>
    </div>

    <div class="discord-generator__field">
      <label>Mensajes cargados</label>
      <div id="discord-list" class="discord-generator__list"></div>
    </div>
  </div>

  <div class="discord-generator__preview-panel">
    <div class="discord-preview">
      <div class="discord-preview__topbar">
        <span class="discord-preview__hash">#</span> general
      </div>
      <div id="discord-preview-messages" class="discord-preview__messages"></div>
    </div>
  </div>
</div>

<script id="discord-initial-messages" type="application/json" set:html={JSON.stringify(initialMessages)}></script>

<script>

  interface DiscordMessage {
    id: string;
    username: string;
    content: string;
    avatar: string;
    color: string;
    timestamp: string;
    isBot: boolean;
  }

  const usernameEl = document.getElementById('discord-username') as HTMLInputElement | null;
  const contentEl = document.getElementById('discord-content') as HTMLTextAreaElement | null;
  const avatarEl = document.getElementById('discord-avatar') as HTMLInputElement | null;
  const avatarFileEl = document.getElementById('discord-avatar-file') as HTMLInputElement | null;
  const colorEl = document.getElementById('discord-color') as HTMLInputElement | null;
  const timeEl = document.getElementById('discord-time') as HTMLInputElement | null;
  const botEl = document.getElementById('discord-bot') as HTMLInputElement | null;
  const addEl = document.getElementById('discord-add') as HTMLButtonElement | null;
  const updateEl = document.getElementById('discord-update') as HTMLButtonElement | null;
  const deleteEl = document.getElementById('discord-delete') as HTMLButtonElement | null;
  const resetEl = document.getElementById('discord-reset') as HTMLButtonElement | null;
  const listEl = document.getElementById('discord-list');
  const previewEl = document.getElementById('discord-preview-messages');
  const initialMessagesEl = document.getElementById('discord-initial-messages');
  const initialMessages = initialMessagesEl?.textContent
    ? JSON.parse(initialMessagesEl.textContent)
    : [];

  const createId = () => {
    if (typeof crypto !== 'undefined' && typeof crypto.randomUUID === 'function') {
      return crypto.randomUUID();
    }
    return `${Date.now()}-${Math.random().toString(36).slice(2)}`;
  };

  const escapeHtml = (value: string) =>
    value
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

  const getInitials = (value: string) => {
    const parts = value.trim().split(/\s+/).filter(Boolean);
    if (parts.length === 0) return '?';
    if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
    return `${parts[0][0]}${parts[1][0]}`.toUpperCase();
  };

  const getDefaultAvatar = (username: string, color: string) => {
    const initials = getInitials(username);
    const safeColor = color || '#5865f2';
    const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="80" height="80"><defs><linearGradient id="g" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="${safeColor}"/><stop offset="100%" stop-color="#4f46e5"/></linearGradient></defs><rect width="80" height="80" fill="url(#g)"/><text x="50%" y="53%" dominant-baseline="middle" text-anchor="middle" font-family="Inter, Arial, sans-serif" font-size="28" font-weight="700" fill="#ffffff">${initials}</text></svg>`;
    return `data:image/svg+xml;charset=UTF-8,${encodeURIComponent(svg)}`;
  };

  const normalizeTimestamp = (rawValue: string) => {
    const value = rawValue.trim();
    if (!value) {
      const now = new Date();
      return `${now.getHours()}:${now.getMinutes().toString().padStart(2, '0')}`;
    }
    const timeMatch = value.match(/(\d{1,2})[:.](\d{2})/);
    if (timeMatch) {
      const hours = Number(timeMatch[1]);
      const minutes = Number(timeMatch[2]);
      if (Number.isInteger(hours) && Number.isInteger(minutes) && hours >= 0 && hours <= 23 && minutes >= 0 && minutes <= 59) {
        return `${hours}:${minutes.toString().padStart(2, '0')}`;
      }
    }
    return value;
  };

  const defaults: DiscordMessage[] = initialMessages.map((message) => ({
    id: createId(),
    username: message.username,
    content: message.content,
    avatar: message.avatar,
    color: message.color,
    timestamp: normalizeTimestamp(message.timestamp),
    isBot: message.isBot,
  }));

  let defaultTemplate: DiscordMessage[] = [...defaults];
  let messages: DiscordMessage[] = [...defaultTemplate.map((message) => ({ ...message, id: createId() }))];
  let selectedId = messages[0]?.id ?? null;

  const getFormMessage = (): DiscordMessage => ({
    id: selectedId ?? createId(),
    username: usernameEl?.value.trim() || 'Usuario',
    content: contentEl?.value.trim() || 'Mensaje',
    avatar: avatarEl?.value.trim() || '',
    color: colorEl?.value || '#59bfff',
    timestamp: normalizeTimestamp(timeEl?.value || ''),
    isBot: botEl?.checked || false,
  });

  const setFormMessage = (message: DiscordMessage) => {
    if (usernameEl) usernameEl.value = message.username;
    if (contentEl) contentEl.value = message.content;
    if (avatarEl) avatarEl.value = message.avatar;
    if (colorEl) colorEl.value = message.color;
    if (timeEl) timeEl.value = normalizeTimestamp(message.timestamp);
    if (botEl) botEl.checked = message.isBot;
  };

  const renderList = () => {
    if (!listEl) return;
    listEl.innerHTML = messages
      .map((message, index) => {
        const activeClass = message.id === selectedId ? 'is-active' : '';
        return `
          <button class="discord-generator__item ${activeClass}" data-id="${message.id}" type="button">
            <span class="discord-generator__item-index">${index + 1}</span>
            <span class="discord-generator__item-user">${escapeHtml(message.username)}</span>
            <span class="discord-generator__item-text">${escapeHtml(message.content)}</span>
          </button>
        `;
      })
      .join('');
  };

  const renderPreview = () => {
    if (!previewEl) return;
    previewEl.innerHTML = messages
      .map((message) => {
        const avatarSrc = message.avatar || getDefaultAvatar(message.username, message.color);
        const avatar = `<img class="discord-preview__avatar-image" src="${escapeHtml(avatarSrc)}" alt="avatar" />`;
        const botBadge = message.isBot ? '<span class="discord-preview__bot">BOT</span>' : '';
        return `
          <article class="discord-preview__message">
            <div class="discord-preview__avatar">${avatar}</div>
            <div class="discord-preview__body">
              <div class="discord-preview__meta">
                <span class="discord-preview__user" style="color:${escapeHtml(message.color)}">${escapeHtml(message.username)}</span>
                ${botBadge}
                <span class="discord-preview__time">${escapeHtml(message.timestamp)}</span>
              </div>
              <p class="discord-preview__text">${escapeHtml(message.content).replaceAll('\n', '<br />')}</p>
            </div>
          </article>
        `;
      })
      .join('');
  };

  const updateAll = () => {
    if (messages.length === 0) {
      messages = [{ ...getFormMessage(), id: createId() }];
      selectedId = messages[0].id;
    }
    renderList();
    renderPreview();
  };

  listEl?.addEventListener('click', (event) => {
    const target = event.target as HTMLElement;
    const button = target.closest('.discord-generator__item') as HTMLButtonElement | null;
    if (!button) return;
    const id = button.dataset.id;
    if (!id) return;
    const found = messages.find((message) => message.id === id);
    if (!found) return;
    selectedId = id;
    setFormMessage(found);
    renderList();
  });

  addEl?.addEventListener('click', () => {
    const nextMessage = { ...getFormMessage(), id: createId() };
    messages.push(nextMessage);
    selectedId = nextMessage.id;
    updateAll();
  });

  updateEl?.addEventListener('click', () => {
    if (!selectedId) return;
    messages = messages.map((message) =>
      message.id === selectedId ? { ...getFormMessage(), id: selectedId } : message,
    );
    updateAll();
  });

  deleteEl?.addEventListener('click', () => {
    if (!selectedId) return;
    const currentIndex = messages.findIndex((message) => message.id === selectedId);
    if (currentIndex === -1) return;
    messages.splice(currentIndex, 1);
    if (messages.length === 0) {
      const fallback = { ...getFormMessage(), id: createId() };
      messages = [fallback];
      selectedId = fallback.id;
      setFormMessage(fallback);
      updateAll();
      return;
    }
    const nextIndex = Math.max(0, currentIndex - 1);
    selectedId = messages[nextIndex].id;
    setFormMessage(messages[nextIndex]);
    updateAll();
  });

  resetEl?.addEventListener('click', () => {
    messages = [...defaultTemplate.map((message) => ({ ...message, id: createId() }))];
    selectedId = messages[0].id;
    setFormMessage(messages[0]);
    updateAll();
  });

  avatarFileEl?.addEventListener('change', () => {
    const file = avatarFileEl.files?.[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = () => {
      const result = typeof reader.result === 'string' ? reader.result : '';
      if (!result) return;
      if (avatarEl) avatarEl.value = result;
      if (!selectedId) return;
      messages = messages.map((message) => (message.id === selectedId ? { ...message, avatar: result } : message));
      updateAll();
    };
    reader.readAsDataURL(file);
  });

  if (messages[0]) {
    setFormMessage(messages[0]);
  }
  updateAll();
</script>

<style>
  .discord-generator,
  .discord-generator__controls,
  .discord-preview {
    font-family: 'gg sans', 'Inter', 'Noto Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .discord-generator {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 20px;
    height: 100%;
    min-height: 0;
  }

  .discord-generator__controls {
    background: #18181b;
    border: 1px solid #2a2a30;
    border-radius: 14px;
    padding: 18px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .discord-generator__title {
    font-size: 1.25rem;
    color: #f4f4f5;
    font-weight: 700;
  }

  .discord-generator__subtitle {
    color: #9ca3af;
    font-size: 0.9rem;
  }

  .discord-generator__field {
    display: flex;
    flex-direction: column;
    gap: 8px;
    color: #cbd5e1;
    font-size: 0.85rem;
  }

  .discord-generator__input {
    width: 100%;
    background: #0f172a;
    border: 1px solid #334155;
    border-radius: 10px;
    padding: 10px 12px;
    color: #e2e8f0;
    font-size: 0.92rem;
    outline: none;
  }

  .discord-generator__file {
    padding: 8px 10px;
  }

  .discord-generator__textarea {
    min-height: 96px;
    resize: vertical;
  }

  .discord-generator__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .discord-generator__color {
    width: 100%;
    height: 42px;
    border-radius: 10px;
    border: 1px solid #334155;
    background: #0f172a;
    padding: 4px;
    cursor: pointer;
  }

  .discord-generator__checkbox {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    color: #cbd5e1;
  }

  .discord-generator__actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
  }

  .discord-generator__button {
    background: #1e293b;
    color: #e2e8f0;
    border: 1px solid #334155;
    border-radius: 10px;
    padding: 10px 12px;
    cursor: pointer;
    font-weight: 600;
  }

  .discord-generator__button--primary {
    background: #5865f2;
    border-color: #7480f8;
    color: #f8f9ff;
  }

  .discord-generator__button--danger {
    background: #7f1d1d;
    border-color: #b91c1c;
  }

  .discord-generator__list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-height: 220px;
    overflow-y: auto;
  }

  :global(.discord-generator__item) {
    display: grid;
    grid-template-columns: 28px minmax(0, 1fr);
    grid-template-rows: auto auto;
    gap: 2px 8px;
    align-items: center;
    border: 1px solid #334155;
    border-radius: 10px;
    background: #0f172a;
    color: #e2e8f0;
    padding: 8px;
    text-align: left;
    cursor: pointer;
  }

  :global(.discord-generator__item.is-active) {
    border-color: #818cf8;
    box-shadow: 0 0 0 1px #818cf8 inset;
  }

  :global(.discord-generator__item-index) {
    grid-row: 1 / span 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #1e293b;
    font-size: 0.78rem;
    color: #cbd5e1;
  }

  :global(.discord-generator__item-user) {
    font-weight: 700;
    font-size: 0.84rem;
  }

  :global(.discord-generator__item-text) {
    color: #94a3b8;
    font-size: 0.78rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .discord-generator__preview-panel {
    background: #18181b;
    border: 1px solid #2a2a30;
    border-radius: 14px;
    overflow: hidden;
    min-height: 0;
  }

  .discord-preview {
    background: #313338;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .discord-preview__topbar {
    height: 52px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.2);
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 16px;
    font-weight: 700;
    color: #f2f3f5;
  }

  .discord-preview__hash {
    color: #949ba4;
  }

  .discord-preview__messages {
    padding: 12px 0;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  :global(.discord-preview__message) {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 2px 16px 14px;
  }

  :global(.discord-preview__avatar) {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #5865f2;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }

  :global(.discord-preview__avatar-image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  :global(.discord-preview__body) {
    flex: 1;
    min-width: 0;
  }

  :global(.discord-preview__meta) {
    display: flex;
    align-items: center;
    gap: 6px;
    line-height: 1.1;
    min-height: 22px;
  }

  :global(.discord-preview__user) {
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.25;
  }

  :global(.discord-preview__bot) {
    background: #5865f2;
    color: #fff;
    font-size: 0.62rem;
    font-weight: 700;
    border-radius: 4px;
    padding: 2px 4px;
    letter-spacing: 0.06em;
  }

  :global(.discord-preview__time) {
    color: #949ba4;
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1.2;
  }

  :global(.discord-preview__text) {
    color: #dbdee1;
    font-size: 1rem;
    line-height: 1.375;
    margin-top: 2px;
    word-break: break-word;
  }

  @media (max-width: 1100px) {
    .discord-generator {
      grid-template-columns: 1fr;
    }
  }
</style>
