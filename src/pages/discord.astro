---
import Layout from '../layouts/Layout.astro';
import DiscordMessageGenerator from '../components/DiscordMessageGenerator.astro';
---

<Layout title="Discord Message Generator">
  <main class="h-screen flex flex-col p-4">
    <header class="mb-4 flex items-center justify-between">
      <div>
        <h1 class="text-3xl text-indigo-400">Discord Fake Messages</h1>
        <p class="text-gray-400">Generador de conversaciones estilo Discord</p>
      </div>

      <a href="/" class="text-sm text-gray-400 hover:text-white">
        ← Volver
      </a>
    </header>

    <div class="flex-1 min-h-0">
      <DiscordMessageGenerator />
    </div>
  </main>
</Layout>
